NODE_ENV=production
LISTEN_PORT=8081
UPSTREAM_HTTP_URL=http://127.0.0.1:8080
UPSTREAM_WS_URL=ws://127.0.0.1:8080
UPSTREAM_WS_FOR_FAST_BOT_URL=ws://127.0.0.1:8080
BLOCKED_PUBKEYS=
WHITELISTED_PUBKEYS=
FILTER_PROXY_EVENTS=true
ENABLE_FORWARD_REQ_HEADERS=true
MAX_WEBSOCKET_PAYLOAD_SIZE=200000
# kind:1 татарча policy is enforced by local override filter.js:
# allow when content contains #татарча OR event has t=татарча tag.
